NEXT_PUBLIC_APP_NAME=CHOD MOP OFFICE
NEXT_PUBLIC_APP_ENV=development

# Mock mode is the safe, no-cost default.
NEXT_PUBLIC_AI_MODE=mock
NEXT_PUBLIC_SHOW_AI_HQ=false
OPENAI_API_KEY=
OPENAI_MODEL=

# Auth.js session signing. Generate with: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3010
NEXTAUTH_URL=http://localhost:3010
NEXT_PUBLIC_AUTH_PROVIDER=google

# Google OAuth application. Do not enable Billing or attach a payment card.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft Entra ID is prepared but disabled until the team has an account.
# Use a free app registration only; do not add a paid subscription.
# The common issuer supports Outlook, Hotmail and Microsoft 365.
AUTH_MICROSOFT_ENABLED=false
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0/

# The immutable first Super Admin.
SUPER_ADMIN_EMAIL=chod.mopteam@gmail.com

# Google Sheets: use a service account and team-owned sheet IDs within free API quotas.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID_USERS=
GOOGLE_SHEET_ID_PM_LOOP=
GOOGLE_SHEET_ID_RENOVATION=
GOOGLE_SHEET_ID_QUOTATION=
# Optional: quotation DB sheet ID used to sync extra fields such as project_type and main_contractor.
GOOGLE_SHEET_ID_TASK_PROJECT=
GOOGLE_SHEET_ID_SOLAR=
GOOGLE_SHEET_ID_DOCUMENTS=
GOOGLE_SHEET_ID_FITOUT_PROJECT=
# Public/read-only Budget Utilize source. Default is the existing live sheet if left blank.
GOOGLE_SHEET_ID_BUDGET_UTILIZE=

# Existing Auto Quotation Google Apps Script deployment. This remains server-only
# so every request passes through CHOD role and quotation permission checks.
QUOTATION_APPS_SCRIPT_URL=

# Optional future Supabase connection. Keep disabled/blank until approved.
NEXT_PUBLIC_USE_SUPABASE=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OTP rule: customer quotation signing links only. Do not enable SMS OTP without approval.
CUSTOMER_SIGNING_OTP_MODE=email
ENABLE_SMS_OTP=false
